# Daana CLI Project - Git Ignore Rules

# Compiled JSON files (auto-generated from YAML)
*.json

# Backup files (created by merge mapping command)
*.bak

# Temporary files
*.tmp
*.temp

# IDE and editor files
.claude
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Shell and user dotfiles
.bash_profile
.bashrc
.profile
.zshrc
.zprofile
.gitconfig
.gitmodules
.ripgreprc

# Environment and configuration overrides
.env
.env.local
*.local.yaml

# Database data and logs (if running locally)
data/
logs/
*.log

# Coverage and test outputs
coverage.txt
test-output.json

# Build artifacts
dist/
build/

# Worktrees
.worktrees/

# Seed data CSVs (downloaded at build time)
db/seed/data/
